{
  "latex-workshop.latex.tools": [
    {
      "name": "wsl-pdflatex",
      "command": "wsl",
      "args": [
        "-d",
        "Ubuntu-24.04",
        "--",
        "bash",
        "-lc",
        "cd \"$(wslpath '%DIR%')\" && pdflatex -synctex=1 -interaction=nonstopmode -file-line-error '%DOCFILE%'"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "wsl-pdflatex",
      "tools": [
        "wsl-pdflatex"
      ]
    }
  ],
  "latex-workshop.latex.recipe.default": "wsl-pdflatex"
}
